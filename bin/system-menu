#!/bin/bash

choice=$(printf "BITS\nCheck Updates\nPower Mode\nPresets - EasyEffects\nServices\nToggle Global Bypass - EasyEffects" | fuzzel --dmenu --minimal-lines)

case "$choice" in
    "Toggle Global Bypass - EasyEffects")
        response=$(easyeffects -b 3)
        if [ $response -eq 0 ]; then
            easyeffects -b 1
            fyi --transient --expire-time=$((3*1000)) --app-name="Easy Effects" --icon="easyeffects" "Enabled Global Bypass"
        else
            easyeffects -b 2
            fyi --transient --expire-time=$((3*1000)) --app-name="Easy Effects" --icon="easyeffects" "Disabled Global Bypass"
        fi
        ;;
    "Power Mode")
        power_choice=$(printf "Low Power\nBalanced\nPerformance" | fuzzel --dmenu --minimal-lines)
        if [[ "$power_choice" == "Low Power" ]]; then
            power_mode="low-power"
        elif [[ "$power_choice" == "Balanced" ]]; then
            power_mode="balanced"
        elif [[ "$power_choice" == "Performance" ]]; then
            power_mode="performance"
        else
            exit 1
        fi
        if echo "$power_mode" | pkexec tee /sys/bus/platform/devices/VPC2004:00/platform-profile/platform-profile-0/profile > /dev/null; then
            fyi --transient --expire-time=$((5*1000)) --icon=$HOME/.config/fastfetch/pngs/niri.png "Power Profile" "$power_choice Mode is now active."
        else
            fyi --transient --expire-time=$((5*1000)) --icon=$HOME/.config/fastfetch/pngs/niri.png "Power Profile" "Something went wrong while applying $power_choice mode."
        fi
        ;;
    "Presets - EasyEffects")
        preset_dir="$HOME/.local/share/easyeffects/output"

        if [ ! -d "$preset_dir" ]; then
            fyi --transient --expire-time=$((3*1000)) --app-name="Easy Effects" --icon="easyeffects" "Preset directory not found."
            exit 1
        fi
        preset=$(find "$preset_dir" -maxdepth 1 -type f -name "*.json" -print0 \
            | xargs -0 -n 1 basename -s .json \
            | fuzzel --dmenu --minimal-lines)

        if [ -n "$preset" ]; then
            easyeffects -l "$preset"
            fyi --transient --expire-time=$((3*1000)) --app-name="Easy Effects" --icon="easyeffects" "Preset applied: $preset"
        fi
        ;;
    "Check Updates")
        check-updates
        ;;
    "BITS")
        wifi_choice=$(printf "Login Wifi\nLogout Wifi" | fuzzel --dmenu --minimal-lines)
        if [[ "$wifi_choice" == "Login Wifi" ]]; then
            response=$(curl 'https://campnet.bits-goa.ac.in:8090/login.xml' \
                -X POST --data-raw 'mode=191&username=h20250138&password=Hd*25707778')
            if echo "$response" | grep -q "<status><!\[CDATA\[LIVE\]\]></status>"; then
                fyi --transient --expire-time=$((3*1000)) --icon="network-wireless-symbolic" "Connected to BITS Wi-Fi"
            else
                fyi --transient --expire-time=$((3*1000)) --icon="dialog-warning-symbolic" "Failed to connect to BITS Wi-Fi"
            fi
        elif [[ "$wifi_choice" == "Logout Wifi" ]]; then
            response=$(curl 'https://campnet.bits-goa.ac.in:8090/logout.xml' \
                -X POST --data-raw 'mode=193&username=h20250138&password=Hd*25707778')
            if echo "$response" | grep -q "<status><!\[CDATA\[LOGIN\]\]></status>"; then
                fyi --transient --expire-time=$((3*1000)) --icon="network-wireless-offline-symbolic" "Disconnected from BITS Wi-Fi"
            else
                fyi --transient --expire-time=$((3*1000)) --icon="dialog-warning-symbolic" "Failed to disconnect from BITS Wi-Fi"
            fi
        fi
        ;;
    "Warp")
        warp_choice=$(printf "Connect Warp\nDisconnect Warp" | fuzzel --dmenu --minimal-lines)

        [[ -z "$warp_choice" ]] && exit 0

        if [[ "$warp_choice" == "Connect Warp" ]]; then
            response=$(warp-cli connect 2>&1)

            if echo "$response" | grep -qi "success\|connected"; then
                fyi --transient --expire-time=$((3*1000)) \
                    --icon="network-vpn-symbolic" \
                    "Warp Connected"
            else
                fyi --transient --expire-time=$((3*1000)) \
                    --icon="dialog-error-symbolic" \
                    "Warp Connection Failed"
            fi

        elif [[ "$warp_choice" == "Disconnect Warp" ]]; then
            response=$(warp-cli disconnect 2>&1)

            if echo "$response" | grep -qi "success\|disconnected"; then
                fyi --transient --expire-time=$((3*1000)) \
                    --icon="network-offline-symbolic" \
                    "Warp Disconnected"
            else
                fyi --transient --expire-time=$((3*1000)) \
                    --icon="dialog-error-symbolic" \
                    "Warp Disconnection Failed"
            fi
        fi
        ;;
    "Services")
        service_dir="$HOME/.config/systemd/user"

        if [ ! -d "$service_dir" ]; then
            fyi --transient --expire-time=$((3*1000)) --icon=$HOME/.config/fastfetch/pngs/niri.png "Service directory not found."
            exit 1
        fi
        service=$(
            {
                find "$service_dir" -maxdepth 1 -name "*.service" -print0 \
                    | xargs -0 -n 1 basename -s .service
                echo "swaync"
                echo "xwayland-satellite"
            } | fuzzel --dmenu --minimal-lines
        )

        if [ -n "$service" ]; then
            start="systemctl --user start $service"
            stop="systemctl --user stop $service"
            restart="systemctl --user restart $service"
            add_wants="systemctl --user add-wants _______ $service"
            command=$(printf "$start\n$stop\n$restart\n$add_wants" | fuzzel --dmenu --minimal-lines)
            if echo "$command" | grep -q "add-wants"; then
                target=$(
                    {
                        echo "niri"
                        find "$service_dir" -maxdepth 1 -name "*.service" -print0 \
                            | xargs -0 -n 1 basename -s .service \
                            | grep -v "^$service\$"
                        echo "swaync"
                        echo "xwayland-satellite"
                    } | fuzzel --dmenu --minimal-lines
                )

                if [ -n "$target" ]; then
                    systemctl --user add-wants "$target.service" "$service.service"
                    fyi --transient --expire-time=$((3*1000)) --icon="$HOME/.config/fastfetch/pngs/niri.png" \
                        "Added $service.service as a Want to $target.service"
                fi
            elif echo "$command" | grep -Eq "start|stop|restart"; then
                eval "$command" &
                action=$(echo "$command" | awk '{print $3}')
                fyi --transient --expire-time=$((3*1000)) \
                    --icon="$HOME/.config/fastfetch/pngs/niri.png" \
                    "Service $service: ${action^}ed"
            fi
        fi
        ;;
    "Virtual Machine")
        systemctl start libvirtd.service && sudo virsh net-start default


esac
